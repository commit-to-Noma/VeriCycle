# ============================================================
#  VeriCycle — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Set to 'production' on Render / any live server
FLASK_ENV=development

# Set to '0' in production (debug output is a security risk)
FLASK_DEBUG=true

# Runtime network for HashScan and Hedera operations
NETWORK=testnet

# Production database URL (Render/Railway/Fly usually inject this)
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ── Hedera Testnet ───────────────────────────────────────────
# Your Hedera operator account (pays for transactions)
OPERATOR_ID=0.0.XXXXXXX
OPERATOR_KEY=302e...your-hex-private-key

# Canonical deployment aliases (app accepts either alias or OPERATOR_* values)
HEDERA_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_PRIVATE_KEY=302e...your-hex-private-key

# HCS topic used for activity anchoring
VERICYCLE_TOPIC_ID=0.0.XXXXXXX

# HTS token used for ECO-coin rewards
ECOCOIN_TOKEN_ID=0.0.XXXXXXX

# Treasury account that holds ECO-coins to distribute
ECOCOIN_TREASURY_ID=0.0.XXXXXXX
ECOCOIN_TREASURY_KEY=302e...treasury-private-key

# ── Demo Mode ────────────────────────────────────────────────
# Set to '1' to activate pre-loaded demo profiles
DEMO_MODE=0

# ── Encryption ───────────────────────────────────────────────
# Key used to encrypt Hedera private keys at rest in the database
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-base64-key-here

# ── Render.com (set automatically by Render, do not change) ──
# RENDER=true
# PORT=10000
